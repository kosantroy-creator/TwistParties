# Booking form email (Resend) — set these in Vercel project env vars.
# Until RESEND_API_KEY is set, /api/inquiry runs in "simulated" mode:
# it logs the submission and returns success so the form is testable.

RESEND_API_KEY=
# Where inquiries are delivered:
BOOKING_TO=hello@twistparties.ca
# Verified sender (use a Resend-verified domain in production):
BOOKING_FROM=Twist Parties <onboarding@resend.dev>

# Google Analytics 4 — set to your Measurement ID (G-XXXXXXXXXX) to enable
# analytics. Left blank, no tracking script loads. Build-time var (VITE_ prefix).
VITE_GA_ID=
